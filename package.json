{
  "name": "@irbisadm/readstat-ts",
  "version": "0.0.0-development",
  "description": "TypeScript port of ReadStat — read and write SPSS (.sav/.zsav/.por), Stata (.dta), and SAS (.sas7bdat/.sas7bcat/.xpt) data files. No native dependencies.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": ["dist", "src", "README.md", "LICENSE", "CHANGELOG.md"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:reference": "bash scripts/build-reference.sh",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run test/e2e",
    "test:watch": "vitest",
    "commitlint": "commitlint",
    "release": "semantic-release",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "spss", "sav", "zsav", "por", "stata", "dta", "sas", "sas7bdat", "sas7bcat",
    "xport", "xpt", "readstat", "statistics", "data", "parser", "port"
  ],
  "author": "irbisadm <i@irbisadm.dev>",
  "license": "MIT",
  "homepage": "https://github.com/irbisadm/readstat-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/irbisadm/readstat-ts.git"
  },
  "bugs": {
    "url": "https://github.com/irbisadm/readstat-ts/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": { "node": ">=18" },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "@types/node": "^20.11.0",
    "conventional-changelog-conventionalcommits": "^8.0.0",
    "semantic-release": "^24.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
