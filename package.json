{
  "name": "readstat-ts",
  "version": "0.1.0",
  "description": "TypeScript port of ReadStat — read and write SPSS (.sav/.zsav/.por), Stata (.dta), and SAS (.sas7bdat/.sas7bcat/.xpt) data files",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:reference": "bash scripts/build-reference.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run test/e2e",
    "test:watch": "vitest"
  },
  "keywords": [
    "spss", "sav", "zsav", "por", "stata", "dta", "sas", "sas7bdat", "sas7bcat",
    "xport", "xpt", "readstat", "statistics", "data"
  ],
  "license": "MIT",
  "engines": { "node": ">=18" },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
